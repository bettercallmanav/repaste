{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.repaste.app",
  "productName": "Repaste",
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": [
    "dist-electron/**/*"
  ],
  "extraResources": [
    {
      "from": "../web/dist",
      "to": "web"
    },
    {
      "from": "build",
      "to": "build",
      "filter": ["**/*.png", "**/*.ico", "**/*.icns"]
    }
  ],
  "mac": {
    "target": ["dmg", "zip"],
    "category": "public.app-category.utilities",
    "icon": "build/icon.icns"
  },
  "win": {
    "target": ["nsis", "zip"],
    "icon": "build/icon.ico"
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "category": "Utility",
    "icon": "build/icons"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
